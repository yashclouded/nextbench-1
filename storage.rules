rules_version = '2';

// ⚠️ Storage rules were previously managed in the Firebase console. This file was
// introduced with the Stories foundation. The `nextbench/**` block below mirrors the
// app's existing Storage usage (post videos, etc.) so adopting repo-managed rules does
// not break current uploads. DIFF THIS AGAINST YOUR CONSOLE RULESET before running
// `firebase deploy` (or deploy with `--only firestore` until you've reconciled them).

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }

    // ── Stories media ─────────────────────────────────────
    // Layout: stories/{authorId}/{storyId}/{file}  (file = media.<ext> | poster.<ext>)
    // Discovery is gated by the Firestore story doc; the token download URL is unguessable.
    match /stories/{authorId}/{storyId}/{file} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == authorId
        && request.resource != null
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 15 * 1024 * 1024)
          || (request.resource.contentType.matches('video/.*') && request.resource.size < 100 * 1024 * 1024)
        );
      allow delete: if isSignedIn() && request.auth.uid == authorId;
    }

    // ── Existing app media (mirrors current console behaviour) ──
    match /nextbench/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Anything not matched above is denied by default (no rule grants access).
  }
}
