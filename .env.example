# ============================================
# NextBench Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Firebase Client SDK Config ---
# Get these from Firebase Console → Project Settings → Your App → SDK Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# --- Cloudinary Config (for free image hosting) ---
# Get these from your Cloudinary Dashboard → Settings → Upload → Upload Presets
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Firestore Database ID ---
# Leave as "(default)" unless using a named database
VITE_FIREBASE_FIRESTORE_DB=(default)
VITE_GIPHY_API_KEY=your_actual_key_here